        "diffHighlightAdded": {
            "dark": "green"
        },
        "diffHighlightRemoved": {
            "dark": "red"
        },
        "diffAddedBg": {
            "dark": "bg1"
        },
        "diffRemovedBg": {
            "dark": "bg1"
