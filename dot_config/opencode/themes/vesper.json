{
    "$schema": "https://opencode.ai/theme.json",
    "defs": {
        "bg0": "#101010",
        "bg1": "#1a1a1a",
        "bg2": "#242424",
        "fg0": "#ffffff",
        "fg1": "#a0a0a0",
        "gray": "#505050",
        "red": "#ff8080",
        "orange": "#ff7300",
        "yellow": "#ffc799",
        "green": "#99ffe4",
        "blue": "#a0a0a0",
        "purple": "#ff7300",
        "aqua": "#99ffe4"
    },
    "theme": {
        "primary": {
            "dark": "blue"
        },
        "secondary": {
            "dark": "purple"
        },
        "accent": {
            "dark": "aqua"
        },
        "error": {
            "dark": "red"
        },
        "warning": {
            "dark": "orange"
        },
        "success": {
            "dark": "green"
        },
        "info": {
            "dark": "yellow"
