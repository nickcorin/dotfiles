        "markdownCodeBlock": {
            "dark": "fg0"
        },
        "syntaxComment": {
            "dark": "fg1"
        },
        "syntaxKeyword": {
            "dark": "red"
        },
        "syntaxFunction": {
            "dark": "green"
        },
        "syntaxVariable": {
            "dark": "blue"
        },
        "syntaxString": {
            "dark": "yellow"
        },
        "syntaxNumber": {
            "dark": "orange"
        },
        "syntaxType": {
            "dark": "aqua"
        },
        "syntaxOperator": {
            "dark": "fg1"
        },
        "syntaxPunctuation": {
            "dark": "fg1"
        }
